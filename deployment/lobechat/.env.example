# The Keep - LobeChat Configuration
# Copy this to .env and fill in values

# =============================================================================
# LiteLLM Connection (AI Model Proxy)
# =============================================================================
LITELLM_URL=http://10.0.0.27:2764/v1
LITELLM_API_KEY=sk-internal

# Default model for new conversations
DEFAULT_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Authentication
# =============================================================================
# Session encryption (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_NEW_SECRET

# Optional: Access code to restrict access (leave empty for open access)
ACCESS_CODE=

# =============================================================================
# Features
# =============================================================================
# Enable/disable features: +tools,+plugins,+upload,-dalle (prefix with - to disable)
FEATURE_FLAGS=+tools,+plugins,+upload
